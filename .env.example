# APP
NEXT_PUBLIC_SITE_URL=
NEXT_PUBLIC_APP_ENV=staging
NEXT_PUBLIC_AUTH_REDIRECT_URL=

# SUPABASE
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
# Optional for newer Supabase projects; if set, app auth can prefer this over anon key.
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# AUTH / INVITE
NEXT_PUBLIC_BETA_INVITE_ONLY=false

# GOOGLE MAPS
GOOGLE_MAPS_API_KEY=
NEXT_PUBLIC_GOOGLE_MAPS_BROWSER_KEY=
# Optional local-only fallback data for map discovery when GOOGLE_MAPS_API_KEY is empty.
ENABLE_DEMO_MAPS=false

# ANALYTICS
NEXT_PUBLIC_POSTHOG_KEY=
NEXT_PUBLIC_POSTHOG_HOST=https://app.posthog.com
NEXT_PUBLIC_CLARITY_PROJECT_ID=
SENTRY_DSN=
NEXT_PUBLIC_SENTRY_DSN=

# AI
AI_PROVIDER=
AI_API_KEY=
AI_MODEL=
AI_DAILY_COST_LIMIT_VND=

# EMAIL
RESEND_API_KEY=
EMAIL_FROM=

# BILLING
NEXT_PUBLIC_BILLING_ENABLED=false
BILLING_ENABLED=false
BILLING_DEFAULT_PROVIDER=manual_bank_transfer
BILLING_ALLOWED_PROVIDERS=manual_bank_transfer,vietqr_manual,payos

# MANUAL BANK TRANSFER
BILLING_BANK_NAME=
BILLING_BANK_ACCOUNT_NUMBER=
BILLING_BANK_ACCOUNT_NAME=
BILLING_BANK_BRANCH=
BILLING_TRANSFER_PREFIX=SALEMAP

# VIETQR MANUAL
VIETQR_ENABLED=true
VIETQR_BANK_BIN=
VIETQR_ACCOUNT_NUMBER=
VIETQR_ACCOUNT_NAME=
VIETQR_TEMPLATE=compact

# PAYOS
PAYOS_ENABLED=false
PAYOS_CLIENT_ID=
PAYOS_API_KEY=
PAYOS_CHECKSUM_KEY=
PAYOS_PARTNER_CODE=

# LEGACY PAYMENT ALIASES
PAYMENT_PROVIDER=
PAYMENT_BANK_NAME=
PAYMENT_BANK_ACCOUNT_NUMBER=
PAYMENT_BANK_ACCOUNT_NAME=

# APP URLS
BILLING_RETURN_PATH=/app/billing/success
BILLING_CANCEL_PATH=/app/billing/cancel

# CRON
CRON_SECRET=

# FEATURE FLAGS
# Runtime feature flags are stored in Supabase tables:
# - public.feature_flags
# - public.user_feature_flags
# Seed them with supabase/seed-staging.sql or manage them from /admin/feature-flags.
