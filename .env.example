# APP
NEXT_PUBLIC_SITE_URL=
NEXT_PUBLIC_APP_ENV=staging
NEXT_PUBLIC_AUTH_REDIRECT_URL=

# SUPABASE
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
# Optional for newer Supabase projects; if set, app auth can prefer this over anon key.
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# AUTH / INVITE
NEXT_PUBLIC_BETA_INVITE_ONLY=false

# GOOGLE MAPS
GOOGLE_MAPS_API_KEY=
NEXT_PUBLIC_GOOGLE_MAPS_BROWSER_KEY=

# ANALYTICS
NEXT_PUBLIC_POSTHOG_KEY=
NEXT_PUBLIC_POSTHOG_HOST=https://app.posthog.com
NEXT_PUBLIC_CLARITY_PROJECT_ID=
SENTRY_DSN=
NEXT_PUBLIC_SENTRY_DSN=

# AI
AI_PROVIDER=
AI_API_KEY=
AI_MODEL=
AI_DAILY_COST_LIMIT_VND=

# EMAIL
RESEND_API_KEY=
EMAIL_FROM=

# PAYMENT
PAYMENT_PROVIDER=
PAYOS_CLIENT_ID=
PAYOS_API_KEY=
PAYOS_CHECKSUM_KEY=
PAYOS_PARTNER_CODE=
PAYMENT_BANK_NAME=
PAYMENT_BANK_ACCOUNT_NUMBER=
PAYMENT_BANK_ACCOUNT_NAME=

# CRON
CRON_SECRET=

# FEATURE FLAGS DEFAULT
NEXT_PUBLIC_ENABLE_MAP_DISCOVERY=true
NEXT_PUBLIC_ENABLE_ROUTE_SEARCH=true
NEXT_PUBLIC_ENABLE_AI_ASSISTANT=false
NEXT_PUBLIC_ENABLE_PAYMENT_GATEWAY=false
NEXT_PUBLIC_ENABLE_IMPORT=true
NEXT_PUBLIC_ENABLE_OFFLINE=true
